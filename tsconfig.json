{
  "compilerOptions": {
    "lib": [
      "dom",
      "esnext"
    ],
    "strictNullChecks": true,
    "moduleResolution": "node",
    "jsx": "react",
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "allowSyntheticDefaultImports": true,
    "target": "es6",
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": [
      "react",
      "react-native"
    ],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ant-design/react-native": ["./components/index.tsx"],
      "@ant-design/react-native/lib/*": ["./components/*"]
    }
  },
  "include": [
    ".dumirc.ts",
    "components/**/*",
    "components/**/*.tsx",
    "components/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "lib",
    "es"
  ],
  "compileOnSave": false
}